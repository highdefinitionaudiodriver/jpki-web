# =====================================================================
# 🔴 重要: 個人情報を含むファイルの除外
# ---------------------------------------------------------------------
# .jpkiimg / .p7s / .der / .cer / .crt / .pem / .pfx / .key には
# 氏名・住所・生年月日・JPKI識別符号などの個人情報、または鍵素材が
# 含まれる可能性があるため、絶対にリポジトリに含めない。
# =====================================================================
*.jpkiimg
*.p7s
*.der
*.cer
*.crt
*.pem
*.pfx
*.p12
*.key

# アップロードされた画像・生成物（.gitkeep だけ残す）
app/uploads/*
!app/uploads/.gitkeep

# 一時ファイル / キャッシュ
*.tmp
*.bak
*.swp
*~

# =====================================================================
# Python
# =====================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg
*.egg-info/
build/
dist/
.eggs/
pip-log.txt
pip-delete-this-directory.txt

# 仮想環境
.venv/
venv/
env/
ENV/

# テスト・カバレッジ
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.mypy_cache/
.ruff_cache/

# =====================================================================
# 環境変数 / シークレット
# =====================================================================
.env
.env.*
!.env.example
*.secret

# =====================================================================
# OS / エディタ
# =====================================================================
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/
*.iml
.vs/

# =====================================================================
# ログ
# =====================================================================
*.log
logs/
